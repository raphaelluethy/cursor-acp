{
  "name": "@raphael/cursor-acp",
  "version": "0.7.1",
  "description": "ACP adapter backed by Cursor Agent CLI",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "cursor-acp": "./dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "start": "bun dist/index.js",
    "dev": "bun run build && bun dist/index.js",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "lint:eslint": "eslint src --ext .ts",
    "lint:eslint:fix": "eslint src --ext .ts --fix",
    "format": "oxfmt --config .oxfmtrc.json --write src",
    "format:check": "oxfmt --config .oxfmtrc.json --check src",
    "format:prettier": "prettier --write .",
    "format:prettier:check": "prettier --check .",
    "typecheck": "tsgo --noEmit",
    "check": "bun run lint && bun run format:check",
    "check:legacy": "bun run lint:eslint && bun run format:prettier:check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "bun run build:clean"
  },
  "keywords": [
    "cursor",
    "acp",
    "agent",
    "typescript",
    "adapter"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "0.22.1",
    "@typescript/native-preview": "^7.0.0-dev.20260430.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
